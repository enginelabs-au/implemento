# Implemento — environment variable template (safe to commit)
# Copy to `.env` and fill in GEMINI_API_KEY + OPENROUTER_API_KEY:
#   cp env.example .env
#
# Model policy (automatic fallback not wired in extension v1 yet):
#   1. gemini-3.5-flash
#   2. gemini-3.1-flash-lite
#   3. gemini-2.5-pro
#   4. gemini-2.5-flash
#   5. openai/gpt-5.4-nano (OpenRouter)
#   6. openai/gpt-5.6-sol-pro (OpenRouter, only after task failure, max $1/day)

# =============================================================================
# API keys
# =============================================================================

GEMINI_API_KEY=
OPENROUTER_API_KEY=

# =============================================================================
# PRIMARY — Google Gemini
# =============================================================================

IMPLEMENTO_LLM_PROVIDER=gemini
IMPLEMENTO_LLM_API_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
IMPLEMENTO_LLM_API_KEY=
IMPLEMENTO_LLM_MODEL=gemini-3.5-flash
IMPLEMENTO_LLM_TEMPERATURE=0.2

# =============================================================================
# GEMINI FALLBACK CHAIN
# =============================================================================

IMPLEMENTO_GEMINI_MODEL_CHAIN=gemini-3.5-flash,gemini-3.1-flash-lite,gemini-2.5-pro,gemini-2.5-flash
IMPLEMENTO_GEMINI_MODEL_FALLBACK_1=gemini-3.1-flash-lite
IMPLEMENTO_GEMINI_MODEL_FALLBACK_2=gemini-2.5-pro
IMPLEMENTO_GEMINI_MODEL_FALLBACK_3=gemini-2.5-flash

# =============================================================================
# OPENROUTER — after all Gemini models fail
# =============================================================================

IMPLEMENTO_LLM_BACKUP_PROVIDER=openrouter
IMPLEMENTO_LLM_BACKUP_API_URL=https://openrouter.ai/api/v1
IMPLEMENTO_LLM_BACKUP_API_KEY=
IMPLEMENTO_LLM_BACKUP_MODEL=openai/gpt-5.4-nano
IMPLEMENTO_LLM_BACKUP_TEMPERATURE=0.2

# =============================================================================
# HARD-TASK ESCALATION — only after a task failed
# =============================================================================

IMPLEMENTO_LLM_HARD_TASK_PROVIDER=openrouter
IMPLEMENTO_LLM_HARD_TASK_API_URL=https://openrouter.ai/api/v1
IMPLEMENTO_LLM_HARD_TASK_API_KEY=
IMPLEMENTO_LLM_HARD_TASK_MODEL=openai/gpt-5.6-sol-pro
IMPLEMENTO_LLM_HARD_TASK_TEMPERATURE=0.2
IMPLEMENTO_LLM_HARD_TASK_TRIGGER=on_task_failure
IMPLEMENTO_LLM_HARD_TASK_MAX_DAILY_USD=1.00

# =============================================================================
# POST-V1 — Reddit OAuth (backend only)
# =============================================================================

REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
