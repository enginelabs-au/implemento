{
  "name": "implemento",
  "version": "1.0.0",
  "private": true,
  "description": "Reddit-native market discovery and solution planning browser extension",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite --config extension/vite.config.ts",
    "build": "tsc --noEmit && vite build --config extension/vite.config.ts",
    "lint": "eslint extension/src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@eslint/js": "^9.17.0",
    "@types/chrome": "^0.0.287",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "@types/node": "^22.10.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8",
    "happy-dom": "^15.11.7"
  }
}
