{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["chrome", "vitest/globals", "node"],
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["extension/src/shared/*"]
    }
  },
  "include": ["extension/src/**/*.ts", "extension/src/**/*.d.ts", "vitest.config.ts"],
  "exclude": ["node_modules", "dist"]
}
